{
  "expo": {
    "name": "SDUI App",
    "slug": "sdui-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "updates": {
      "enabled": false
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.sduiapp"
    },
    "android": {
      "package": "com.example.sduiapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
